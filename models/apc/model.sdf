<?xml version="1.0"?>
<sdf version="1.9">
  <model name="apc">
    <static>false</static>

    <!-- Body: box 2.5 x 1.2 x 0.8 m, mass 15000 kg -->
    <link name="base_link">
      <inertial>
        <mass>15000</mass>
        <inertia>
          <ixx>2600.00</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>8612.50</iyy><iyz>0</iyz>
          <izz>9612.50</izz>
        </inertia>
      </inertial>
      <collision name="body_collision">
        <geometry>
          <box><size>2.5 1.2 0.8</size></box>
        </geometry>
      </collision>
      <visual name="body_visual">
        <geometry>
          <box><size>2.5 1.2 0.8</size></box>
        </geometry>
        <material>
          <ambient>0.82 0.71 0.55 1</ambient>
          <diffuse>0.82 0.71 0.55 1</diffuse>
        </material>
      </visual>

      <!-- 2D Lidar sensor (360 deg, 200 m range, 10 Hz) -->
      <sensor name="lidar" type="gpu_lidar">
        <pose>0 0 0.45 0 0 0</pose>
        <topic>scan</topic>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>6.283185</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.3</min>
            <max>200.0</max>
          </range>
        </lidar>
        <always_on>true</always_on>
        <visualize>true</visualize>
      </sensor>

      <!-- IMU sensor (50 Hz) -->
      <sensor name="imu" type="imu">
        <update_rate>50</update_rate>
        <always_on>true</always_on>
      </sensor>

      <!-- Contact sensor -->
      <sensor name="contact" type="contact">
        <contact>
          <collision>body_collision</collision>
        </contact>
        <update_rate>10</update_rate>
        <always_on>true</always_on>
      </sensor>
    </link>

    <!-- Left wheel -->
    <link name="left_wheel">
      <pose>0 0.6 -0.275 -1.5708 0 0</pose>
      <inertial>
        <mass>50</mass>
        <inertia>
          <ixx>0.2604</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.2604</iyy><iyz>0</iyz>
          <izz>0.3906</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder><radius>0.125</radius><length>0.08</length></cylinder>
        </geometry>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder><radius>0.125</radius><length>0.08</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="right_wheel">
      <pose>0 -0.6 -0.275 -1.5708 0 0</pose>
      <inertial>
        <mass>50</mass>
        <inertia>
          <ixx>0.2604</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.2604</iyy><iyz>0</iyz>
          <izz>0.3906</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder><radius>0.125</radius><length>0.08</length></cylinder>
        </geometry>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder><radius>0.125</radius><length>0.08</length></cylinder>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Caster (frictionless sphere) -->
    <link name="caster">
      <pose>-1.0 0 -0.36 0 0 0</pose>
      <inertial>
        <mass>25</mass>
        <inertia>
          <ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.01</iyy><iyz>0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>
      <collision name="caster_collision">
        <geometry>
          <sphere><radius>0.04</radius></sphere>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0</mu><mu2>0</mu2></ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Joints -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis><xyz>0 0 1</xyz></axis>
    </joint>
    <joint name="caster_joint" type="ball">
      <parent>base_link</parent>
      <child>caster</child>
    </joint>

    <!-- Differential drive plugin -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>1.2</wheel_separation>
      <wheel_radius>0.125</wheel_radius>
      <max_linear_acceleration>5.0</max_linear_acceleration>
      <max_linear_velocity>25.0</max_linear_velocity>
      <max_angular_velocity>0.8</max_angular_velocity>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
    </plugin>

    <!-- Pose publisher -->
    <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
      <publish_link_pose>false</publish_link_pose>
      <publish_model_pose>true</publish_model_pose>
      <update_frequency>50</update_frequency>
    </plugin>
  </model>
</sdf>
